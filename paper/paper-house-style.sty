%
% Shared house typography for the repository's rendered papers.  Under
% Tectonic (XeTeX) the text and mathematics are set in TeX Gyre Pagella from
% the bundled OpenType fonts, with a Heros sans range for \mathsf and
% Inconsolata for monospace; the pdflatex fallback keeps the same Palatino
% design through newpx.  The A4 text block uses a classical measure with
% quiet running heads and restrained ink.  Link colours: steel blue for
% external (Lean-source and web) targets, deep burgundy for internal
% cross-references and citations.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{paper-house-style}[2026/07/19 Pagella house style for the papers]

\RequirePackage{iftex}
\RequirePackage{amsmath}
\RequirePackage{amsthm}
\ifpdftex
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
  \RequirePackage{amssymb}
  \RequirePackage{newpxtext}
  \RequirePackage{newpxmath}
\else
  \RequirePackage{fontspec}
  \RequirePackage{unicode-math}
  \setmainfont{texgyrepagella}[Extension=.otf,UprightFont=*-regular,
    BoldFont=*-bold,ItalicFont=*-italic,BoldItalicFont=*-bolditalic]
  \setmathfont{texgyrepagella-math.otf}
  \setmathfont{texgyreheros-regular.otf}[range=sfup,Scale=MatchLowercase]
  \setmonofont{Inconsolatazi4}[Extension=.otf,UprightFont=*-Regular,
    BoldFont=*-Bold,Scale=MatchLowercase]
\fi

\RequirePackage[a4paper,textwidth=418pt,textheight=636pt,hcentering,
  top=68pt,headheight=15pt,headsep=20pt,footskip=34pt]{geometry}
\RequirePackage{microtype}
\linespread{1.045}
\clubpenalty=10000 \widowpenalty=10000 \tolerance=1600

\RequirePackage[dvipsnames]{xcolor}
\definecolor{linkexternal}{HTML}{275D8C}
\definecolor{linkinternal}{HTML}{6E2B2B}

\RequirePackage{titlesec}
\titleformat{\section}{\Large\bfseries}{\thesection}{0.85em}{}
\titlespacing*{\section}{0pt}{2.6ex plus .8ex minus .3ex}{1.5ex plus .3ex}
\titleformat{\subsection}{\large\bfseries}{\thesubsection}{0.8em}{}
\titlespacing*{\subsection}{0pt}{2.1ex plus .6ex minus .2ex}{1.1ex plus .2ex}
\titlespacing*{\paragraph}{0pt}{1.6ex plus .5ex minus .2ex}{0.85em}

\RequirePackage{fancyhdr}
\newcommand{\paperrunninghead}{}
\newcommand{\runninghead}[1]{\renewcommand{\paperrunninghead}{#1}}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\itshape\paperrunninghead}
\fancyhead[R]{\small\thepage}
\renewcommand{\headrulewidth}{0pt}
\fancypagestyle{plain}{\fancyhf{}\renewcommand{\headrulewidth}{0pt}}

\RequirePackage{caption}
\captionsetup{font=small,labelfont=bf,skip=9pt,width=.92\linewidth}
\renewcommand{\arraystretch}{1.12}

% Front matter: title block with an optional italic subtitle, small-caps
% author, and a hairline rule; the abstract is set small with a small-caps
% head and symmetric indents.
\newcommand{\subtitle}[1]{\gdef\@papersubtitle{#1}}
\renewenvironment{abstract}{%
  \vspace{0.1em}\small
  \begin{center}{\normalsize\scshape Abstract}\end{center}\vspace{-0.5em}
  \list{}{\leftmargin 1.3em\rightmargin\leftmargin\listparindent 0pt
    \parsep 0.32em\itemindent 0pt}\item\relax}
  {\endlist\vspace{0.5em}}
\def\@maketitle{%
  \newpage\null
  \vspace*{-2.6em}%
  \begin{center}%
    {\LARGE\bfseries\@title\par}%
    \vskip 0.55em
    {\large\itshape\@papersubtitle\par}%
    \vskip 1.1em
    {\scshape\@author\par}%
    \vskip 0.25em
    {\small\@date\par}%
    \vskip 0.8em
    \rule{6.5em}{0.4pt}%
  \end{center}%
  \vskip 0.9em}

% Production provenance, set at the foot of the first page.
%
% A reader who meets a single personal byline ordinarily infers that the named
% author drafted the sentences.  For these papers that inference is false, and
% a declaration reached only in the back matter would leave it standing for the
% length of the paper.  The note therefore appears on page one, small and
% visually subordinate to the title and abstract: enough to prevent the false
% inference, not enough to make the production method the subject.
%
% It carries no mark, because it qualifies the whole manuscript rather than any
% one passage.  \footnotetext does not advance the footnote counter, and the
% emptied \thefootnote is confined to a group, so numbered footnotes elsewhere
% in the paper are unaffected.
%
% The wording is not authored here.  It is fixed by the corpus provenance
% contract and reproduced verbatim in each manuscript, so that the three papers
% cannot drift into three different accounts of how they were made.
\newcommand{\provenancenote}[1]{%
  \begingroup
  \renewcommand{\thefootnote}{}%
  \footnotetext{#1}%
  \endgroup}

\endinput
